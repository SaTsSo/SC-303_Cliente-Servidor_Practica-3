            </constraints>
            <properties>
              <text value="Agregar al carrito"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="panelResultado" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="8" left="8" bottom="8" right="8"/>
        <constraints>
