<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="GUI.Inicio">
  <grid id="27dc6" binding="PanelInicio" layout-manager="GridLayoutManager" row-count="4" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="12">
    <margin top="16" left="16" bottom="16" right="16"/>
    <constraints>
      <xy x="20" y="20" width="520" height="380"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="panelBusqueda" layout-manager="GridLayoutManager" row-count="3" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="8" vgap="8">
